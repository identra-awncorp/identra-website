{
  "name": "identra-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "npm run generate:seo && vite build && npm run generate:localized-pages",
    "preview": "vite preview",
    "clean": "node scripts/clean.mjs",
    "generate:seo": "tsx scripts/generate-seo-assets.ts",
    "generate:localized-pages": "tsx scripts/generate-localized-pages.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 170",
    "test": "node --import tsx --test tests/routes.test.ts",
    "check": "npm run typecheck && npm run lint && npm test && npm run scan:all",
    "scan:all": "npm run scan:assets && npm run scan:interactions && npm run scan:duplicate-ctas && npm run scan:localization && npm run scan:i18n-architecture && npm run scan:component-translation-data && npm run scan:routing-types && npm run scan:translation-encoding && npm run scan:translation-inheritance",
    "scan:assets": "node scripts/asset-path-scanner.mjs",
    "scan:interactions": "node scripts/interactive-control-scanner.mjs",
    "scan:duplicate-ctas": "node scripts/remove-duplicate-sandbox-ctas.mjs",
    "scan:localization": "node scripts/localization-scanner.mjs --path src/components --summary",
    "scan:i18n-architecture": "node scripts/i18n-architecture-scanner.mjs --path src/components --summary",
    "scan:component-translation-data": "node scripts/component-translation-data-scanner.mjs --path src/components --summary",
    "scan:routing-types": "node scripts/routing-type-scanner.mjs --path src --summary",
    "scan:translation-encoding": "node scripts/translation-encoding-scanner.mjs --path src --extra vite.config.ts --summary",
    "scan:translation-inheritance": "node scripts/translation-inheritance-scanner.mjs --path src/translations --summary"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "prismjs": "^1.30.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.18.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.14.0",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.65.0",
    "vite": "^6.2.3"
  }
}
